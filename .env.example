# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ─── Anthropic AI ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── GitHub (optional — for auto-sync) ────────
GITHUB_USERNAME=sahilsingh
GITHUB_TOKEN=your_github_token_here  # Personal Access Token — needed to avoid rate limits

# ─── Frontend Origin (CORS) ───────────────────
FRONTEND_URL=http://localhost:3000
# In production: FRONTEND_URL=https://sahilsingh.vercel.app
